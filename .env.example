# ── SSRF-BOX Environment Configuration ─────────────────────────────────────
# Copia este archivo como .env y rellena los valores antes de ejecutar.

# Tu dominio OOB (el NS record de este dominio debe apuntar a tu VPS)
SSRF_DOMAIN=oob.tudominio.com

# IP pública de tu VPS (sin protocolo, solo la IP)
VPS_IP=1.2.3.4

# API key para acceder al dashboard admin (cámbiala, mínimo 32 caracteres)
API_KEY=cambia-esto-por-una-clave-segura-de-32-chars

# Clave interna para comunicación entre contenedores (no expuesta al exterior)
INTERNAL_API_KEY=clave-interna-entre-contenedores-muy-larga

# ── TLS (elige UNA opción) ───────────────────────────────────────────────────

# Opción A — Auto-TLS con Let's Encrypt (recomendado)
# Pon aquí tu dominio OOB exacto. El servidor obtiene el cert automáticamente
# via HTTP-01 challenge. El dominio debe resolver a este VPS.
# NOTA: emite cert solo para el dominio base, no wildcard.
# Los payloads de subdominio siguen capturando via DNS; usa rutas para HTTPS.
# Ej: AUTO_TLS_DOMAIN=oob.tudominio.com
AUTO_TLS_DOMAIN=

# Opción B — Certificado manual (certbot, etc.)
# Rutas DENTRO del contenedor al certificado y clave privada.
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── Notificaciones (opcional) ───────────────────────────────────────────────
# Discord webhook URL para alertas en tiempo real
DISCORD_WEBHOOK=

# Bot de Telegram para alertas
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack incoming webhook para alertas
SLACK_WEBHOOK=
